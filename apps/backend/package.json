{
  "name": "saas-builder-api",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "NODE_ENV=test tsx --test --test-concurrency=1 \"tests/**/*.test.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.975.0",
    "@aws-sdk/s3-request-presigner": "3.975.0",
    "@prisma/client": "6.19.2",
    "argon2": "0.41.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "8.2.1",
    "geoip-lite": "^1.4.10",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "libphonenumber-js": "1.12.35",
    "nodemailer": "6.10.1",
    "otplib": "12.0.1",
    "pino": "10.3.0",
    "pino-http": "11.0.0",
    "rate-limit-redis": "4.3.1",
    "redis": "5.10.0",
    "stripe": "16.10.0",
    "twilio": "5.8.1",
    "yazl": "3.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.0.10",
    "@types/nodemailer": "6.4.17",
    "@types/supertest": "6.0.3",
    "@types/yazl": "3.3.0",
    "prisma": "6.19.2",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
