generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  pending_email
  pending_phone
  pending_mfa
  active
  banned
}

enum UserRole {
  user
  premium
  vip
  admin
  super_admin
}

enum OAuthProvider {
  google
  github
}

enum MfaType {
  totp
}

enum PhoneVerificationStatus {
  pending
  approved
  denied
  expired
}

enum AuthAttemptType {
  login
  phone_start
  phone_check
  billing_checkout
  gdpr_export
}

enum PlanCode {
  FREE
  PREMIUM
  VIP
}

enum Currency {
  EUR
}

enum BillingInterval {
  month
}

enum SubscriptionStatus {
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum WebhookStatus {
  processed
  ignored
  failed
}

enum RoleType {
  premium
  vip
}

enum FileKind {
  avatar
  gdpr_export
  import
  other
}

enum FileStatus {
  pending
  active
  deleted
}

enum GdprExportStatus {
  queued
  building
  ready
  failed
  expired
}

enum DeletionRequestStatus {
  requested
  scheduled
  completed
  failed
}

enum JobStatus {
  queued
  running
  succeeded
  failed
}

enum JobType {
  GDPR_EXPORT
  GDPR_PURGE
}

enum ConsentSource {
  signup
  settings
  banner
}

enum SecurityActionType {
  REVOKE_SESSIONS
  ACK_ALERT
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String?  @map("password_hash")
  status             UserStatus @default(pending_email)
  roles              UserRole[] @default([user])
  firstName          String?  @map("first_name")
  lastName           String?  @map("last_name")
  username           String?  @unique
  nationality        String?
  avatarFileId       String?  @unique @map("avatar_file_id") @db.Uuid
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  emailVerifiedAt    DateTime? @map("email_verified_at")
  phoneVerifiedAt    DateTime? @map("phone_verified_at")
  recoveryEmail      String?  @unique @map("recovery_email")
  recoveryEmailVerifiedAt DateTime? @map("recovery_email_verified_at")
  recoveryEmailPending String? @map("recovery_email_pending")
  mfaEnabled         Boolean  @default(false) @map("mfa_enabled")
  mfaRequiredOverride Boolean? @map("mfa_required_override")
  securityAlertEmailEnabled Boolean @default(false) @map("security_alert_email_enabled")
  securityAlertSmsEnabled Boolean @default(false) @map("security_alert_sms_enabled")
  locale             String?
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  sessions           Session[]
  oauthAccounts      OAuthAccount[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  phoneVerifications PhoneVerification[]
  mfaFactors          MfaFactor[]
  backupCodes         BackupCode[]
  recoveryEmailTokens RecoveryEmailToken[]
  securityActionTokens SecurityActionToken[]
  authAttempts        AuthAttempt[]
  stripeCustomer      StripeCustomer?
  subscriptions       Subscription[]
  payments            Payment[]
  entitlements        Entitlement?
  roleGrants          RoleGrant[]
  files               File[]   @relation("UserFiles")
  gdprExports         GdprExport[]
  deletionRequests    DeletionRequest[]
  consents            Consent[]
  avatarFile          File?    @relation("UserAvatar", fields: [avatarFileId], references: [id])

  @@map("users")
}

model SecurityActionToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    SecurityActionType
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "security_action_tokens_user_id_idx")
  @@map("security_action_tokens")
}

model File {
  id             String    @id @default(uuid()) @db.Uuid
  ownerUserId    String    @map("owner_user_id")
  kind           FileKind
  bucket         String
  objectKey      String    @unique @map("object_key")
  mimeType       String    @map("mime_type")
  sizeBytes      Int       @map("size_bytes")
  checksumSha256 String?   @map("checksum_sha256")
  status         FileStatus @default(pending)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  owner          User      @relation("UserFiles", fields: [ownerUserId], references: [id], onDelete: Cascade)
  avatarUser     User?     @relation("UserAvatar")
  gdprExport     GdprExport? @relation("ExportFile")

  @@index([ownerUserId], name: "files_owner_user_id_idx")
  @@map("files")
}

model GdprExport {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  fileId      String?         @unique @map("file_id") @db.Uuid
  status      GdprExportStatus
  requestedAt DateTime        @default(now()) @map("requested_at")
  readyAt     DateTime?       @map("ready_at")
  expiresAt   DateTime?       @map("expires_at")
  errorMessage String?        @map("error_message")

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  file        File?           @relation("ExportFile", fields: [fileId], references: [id])

  @@index([userId], name: "gdpr_exports_user_id_idx")
  @@index([status], name: "gdpr_exports_status_idx")
  @@map("gdpr_exports")
}

model DeletionRequest {
  id           String               @id @default(cuid())
  userId       String               @map("user_id")
  status       DeletionRequestStatus
  requestedAt  DateTime             @default(now()) @map("requested_at")
  scheduledFor DateTime             @map("scheduled_for")
  completedAt  DateTime?            @map("completed_at")
  errorMessage String?              @map("error_message")

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "deletion_requests_user_id_idx")
  @@index([status], name: "deletion_requests_status_idx")
  @@map("deletion_requests")
}

model Job {
  id         String   @id @default(cuid())
  type       JobType
  payloadJson Json    @map("payload_json")
  status     JobStatus @default(queued)
  attempts   Int      @default(0)
  runAfter   DateTime @map("run_after")
  lockedAt   DateTime? @map("locked_at")
  lockedBy   String?  @map("locked_by")
  lastError  String?  @map("last_error")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([status, runAfter], name: "jobs_status_run_after_idx")
  @@map("jobs")
}

model Plan {
  id           String         @id @default(cuid())
  code         PlanCode       @unique
  name         String
  currency     Currency
  stripePriceId String?       @map("stripe_price_id")
  amountCents  Int            @map("amount_cents")
  interval     BillingInterval
  isActive     Boolean        @default(true) @map("is_active")
  features     Json?          @map("features_json")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("plans")
}

model StripeCustomer {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  stripeCustomerId String   @unique @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "stripe_customers_user_id_idx")
  @@map("stripe_customers")
}

model Subscription {
  id                  String             @id @default(cuid())
  userId              String             @map("user_id")
  planCode            PlanCode           @map("plan_code")
  status              SubscriptionStatus
  currency            Currency
  stripeSubscriptionId String?           @unique @map("stripe_subscription_id")
  currentPeriodStart  DateTime           @map("current_period_start")
  currentPeriodEnd    DateTime           @map("current_period_end")
  cancelAtPeriodEnd   Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt          DateTime?          @map("canceled_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "subscriptions_user_id_idx")
  @@index([stripeSubscriptionId], name: "subscriptions_stripe_subscription_id_idx")
  @@map("subscriptions")
}

model Payment {
  id                     String        @id @default(cuid())
  userId                 String        @map("user_id")
  stripeCheckoutSessionId String?      @unique @map("stripe_checkout_session_id")
  stripeInvoiceId        String?       @unique @map("stripe_invoice_id")
  stripePaymentIntentId  String?       @unique @map("stripe_payment_intent_id")
  amountCents            Int           @map("amount_cents")
  currency               Currency
  status                 PaymentStatus
  createdAt              DateTime      @default(now()) @map("created_at")

  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "payments_user_id_idx")
  @@map("payments")
}

model Entitlement {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  projectsLimit Int?    @map("projects_limit")
  projectsUsed Int      @default(0) @map("projects_used")
  periodStart  DateTime @map("period_start")
  periodEnd    DateTime @map("period_end")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "entitlements_user_id_idx")
  @@map("entitlements")
}

model WebhookEvent {
  id          String        @id @default(cuid())
  provider    String
  eventId     String        @unique @map("event_id")
  type        String
  receivedAt  DateTime      @default(now()) @map("received_at")
  processedAt DateTime?     @map("processed_at")
  status      WebhookStatus
  errorMessage String?      @map("error_message")

  @@index([provider], name: "webhook_events_provider_idx")
  @@map("webhook_events")
}

model RoleGrant {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  role       RoleType
  grantedAt  DateTime  @default(now()) @map("granted_at")
  revokedAt  DateTime? @map("revoked_at")
  reason     String?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "role_grants_user_id_idx")
  @@map("role_grants")
}

model OAuthAccount {
  id             String   @id @default(cuid())
  provider       OAuthProvider
  providerUserId String   @map("provider_user_id")
  userId         String   @map("user_id")
  emailAtProvider String? @map("email_at_provider")
  linkedAt       DateTime @default(now()) @map("linked_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId], name: "oauth_accounts_provider_provider_user_id_key")
  @@index([userId], name: "oauth_accounts_user_id_idx")
  @@map("oauth_accounts")
}

model Session {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  refreshTokenHash    String   @unique @map("refresh_token_hash")
  createdAt           DateTime @default(now()) @map("created_at")
  expiresAt           DateTime @map("expires_at")
  rotatedAt           DateTime? @map("rotated_at")
  revokedAt           DateTime? @map("revoked_at")
  replacedBySessionId String?  @map("replaced_by_session_id")
  ip                  String?
  userAgent           String?  @map("user_agent")
  deviceFingerprint   String?  @map("device_fingerprint")
  lastUsedAt          DateTime @default(now()) @map("last_used_at")

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBySession   Session? @relation("SessionReplacement", fields: [replacedBySessionId], references: [id])
  replacements        Session[] @relation("SessionReplacement")

  @@index([userId], name: "sessions_user_id_idx")
  @@index([expiresAt], name: "sessions_expires_at_idx")
  @@map("sessions")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "email_verification_tokens_user_id_idx")
  @@map("email_verification_tokens")
}

model RecoveryEmailToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  email     String   @map("email")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "recovery_email_tokens_user_id_idx")
  @@map("recovery_email_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "password_reset_tokens_user_id_idx")
  @@map("password_reset_tokens")
}

model PhoneVerification {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  phoneE164   String   @map("phone_e164")
  providerSid String   @map("provider_sid")
  status      PhoneVerificationStatus @default(pending)
  attempts    Int      @default(0)
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "phone_verifications_user_id_idx")
  @@map("phone_verifications")
}

model MfaFactor {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  type          MfaType
  secretEncrypted String @map("secret_encrypted")
  enabledAt     DateTime? @map("enabled_at")
  lastUsedAt    DateTime? @map("last_used_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "mfa_factors_user_id_idx")
  @@map("mfa_factors")
}

model BackupCode {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  codeHash  String   @unique @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "backup_codes_user_id_idx")
  @@map("backup_codes")
}

model AuthAttempt {
  id         String   @id @default(cuid())
  type       AuthAttemptType
  email      String?
  ip         String?
  userAgent  String? @map("user_agent")
  success    Boolean @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  user       User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String? @map("user_id")

  @@index([type, createdAt], name: "auth_attempts_type_created_at_idx")
  @@index([email, createdAt], name: "auth_attempts_email_created_at_idx")
  @@index([ip, createdAt], name: "auth_attempts_ip_created_at_idx")
  @@map("auth_attempts")
}

model AuditLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now()) @map("timestamp")
  actorUserId String?  @map("actor_user_id")
  actorIp    String?  @map("actor_ip")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?    @map("metadata_json")
  requestId  String?  @map("request_id")

  @@index([actorUserId], name: "audit_logs_actor_user_id_idx")
  @@index([timestamp], name: "audit_logs_timestamp_idx")
  @@map("audit_logs")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  valueBoolean Boolean  @map("value_boolean")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  valueJson   Json     @map("value_json")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model DataSubject {
  id          String   @id @default(cuid())
  subjectType String   @map("subject_type")
  subjectRef  String?  @map("subject_ref")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("data_subjects")
}

model Consent {
  id               String        @id @default(cuid())
  userId           String        @map("user_id")
  analyticsEnabled Boolean       @map("analytics_enabled")
  adsEnabled       Boolean       @map("ads_enabled")
  consentVersion   String        @map("consent_version")
  consentedAt      DateTime      @map("consented_at")
  source           ConsentSource
  ipHash           String?       @map("ip_hash")
  userAgentHash    String?       @map("user_agent_hash")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "consents_user_id_idx")
  @@map("consents")
}
